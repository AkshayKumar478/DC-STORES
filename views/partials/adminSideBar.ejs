<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
<nav class="admin-sidebar" id="sidebar">
    <div class="admin-sidebar__header">
        <img src="/images/logo.svg" alt="Admin Logo">
        <p>Admin Panel</p>
    </div>
    <ul class="nav flex-column admin-sidebar__nav">
        <li class="nav-item">
            <a class="nav-link" href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i><span>Dashboard</span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/admin/users"><i class="fas fa-users"></i><span>Manage Users</span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href='/admin/products'><i class="fas fa-box"></i><span>Manage Products</span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/admin/orders"><i class="fas fa-receipt"></i><span>Manage Orders</span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/admin/categories"><i class="fas fa-th-list"></i><span>Manage Categories</span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/admin/coupons"><i class="fa-solid fa-ticket"></i><span>Coupon Management</span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/admin/offers/manage"><i class="fa-solid fa-tags"></i><span>Offers</span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="/admin/sales-report"><i class="fa-solid fa-clipboard-list"></i><span>Sales Report</span></a>
        </li>
        <li class="nav-item">
            <a class="nav-link admin-sidebar__logout" href="/admin/logout"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
        </li>
    </ul>
</nav>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const currentPath = window.location.pathname.toLowerCase();
        document.querySelectorAll('.admin-sidebar .nav-link').forEach(link => {
            const href = link.getAttribute('href').toLowerCase();
            if ((href === '/admin/dashboard' && (currentPath === '/admin/dashboard' || currentPath === '/admin/dashboard/')) ||
                (href !== '/admin/dashboard' && currentPath.startsWith(href))) {
                link.classList.add('is-active');
            }
        });
    });
</script>
