<link rel="stylesheet" href="/stylesheets/adminOffers.css">

<div class="main-content offers-page">
    <div class="admin-page">
        <% if (message) { %>
            <div class="message <%= message.includes('Error') ? 'error' : 'success' %>">
                <%= message %>
            </div>
        <% } %>

        <div class="admin-page-header">
            <div>
                <p class="admin-page-header__eyebrow">Offers</p>
                <h1>Manage Offers</h1>
                <p class="admin-page-subtitle">Set up category, product, and referral offers with the same admin theme.</p>
            </div>
        </div>

        <div class="admin-card offer-form-card mb-4">
            <div class="admin-card__body">
                <div class="admin-page-header mb-3">
                    <div>
                        <h2 class="h4 mb-2">Create New Offer</h2>
                        <p class="admin-page-subtitle mb-0">Choose an offer type and configure the discount details below.</p>
                    </div>
                </div>

                <form action="/admin/offers/add" method="POST" id="offerForm" class="admin-form-card p-0 border-0 shadow-none">
                    <div class="admin-form-grid">
                        <div class="form-group">
                            <label>Select Offer Type</label>
                            <select id="offerTypeSelect" class="form-control" onchange="showOfferForm()">
                                <option value="">Select Type</option>
                                <option value="CATEGORY">Category Offer</option>
                                <option value="PRODUCT">Product Offer</option>
                                <option value="REFERRAL">Referral Offer</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Offer Name</label>
                            <input type="text" name="name" class="form-control" required>
                            <input type="hidden" name="type" id="offerType">
                        </div>

                        <div class="form-group">
                            <label>Discount Type</label>
                            <select name="discountType" class="form-control" required onchange="toggleMaxDiscount()">
                                <option value="PERCENTAGE">Percentage</option>
                                <option value="FLAT">Flat Amount</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Discount Value</label>
                            <input type="number" name="discountValue" class="form-control" required min="0">
                        </div>

                        <div class="form-group" id="maxDiscountDiv">
                            <label>Maximum Discount Amount</label>
                            <input type="number" name="maxDiscountAmount" class="form-control" min="0">
                        </div>
                        <div class="form-group">
                            <label>Minimum Product Price</label>
                            <input type="number" name="minProductPrice" class="form-control" min="0">
                        </div>

                        <div class="form-group">
                            <label>Start Date</label>
                            <input type="datetime-local" name="startDate" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label>End Date</label>
                            <input type="datetime-local" name="endDate" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label>Usage Limit (0 for unlimited)</label>
                            <input type="number" name="usageLimit" class="form-control" min="0">
                        </div>
                    </div>

                    <div id="categoryForm" class="offer-form mt-3">
                        <div class="form-group">
                            <label>Select Category</label>
                            <select name="categoryId" class="form-control">
                                <% categories.forEach(function(category) { %>
                                    <option value="<%= category._id %>"><%= category.name %></option>
                                <% }); %>
                            </select>
                        </div>
                    </div>

                    <div id="productForm" class="offer-form mt-3">
                        <div class="form-group">
                            <label>Select Product</label>
                            <select name="productId" class="form-control">
                                <% products.forEach(function(product) { %>
                                    <option value="<%= product._id %>"><%= product.productName %></option>
                                <% }); %>
                            </select>
                        </div>
                    </div>

                    <div id="referralForm" class="offer-form mt-3">
                        <div class="admin-form-grid">
                            <div class="form-group">
                                <label>Referrer Bonus</label>
                                <input type="number" name="referralDetails.referrerBonus" class="form-control" min="0">
                            </div>
                            <div class="form-group">
                                <label>Referee Bonus</label>
                                <input type="number" name="referralDetails.refereeBonus" class="form-control" min="0">
                            </div>
                            <div class="form-group">
                                <label>Maximum Referrals</label>
                                <input type="number" name="referralDetails.maxReferrals" class="form-control" min="1">
                            </div>
                        </div>
                    </div>

                    <div class="admin-actions mt-4">
                        <button type="submit" class="btn btn-primary">Create Offer</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="admin-card offer-form-card">
            <div class="admin-card__body">
                <div class="admin-page-header mb-3">
                    <div>
                        <h2 class="h4 mb-2">Current Offers</h2>
                        <p class="admin-page-subtitle mb-0">View validity, status, and usage from one organized table.</p>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table admin-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Type</th>
                                <th>Discount</th>
                                <th>Valid Until</th>
                                <th>Status</th>
                                <th>Usage</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% offers.forEach(function(offer) { %>
                                <tr>
                                    <td><strong><%= offer.name %></strong></td>
                                    <td><%= offer.type %></td>
                                    <td>
                                        <%= offer.discountValue %>
                                        <%= offer.discountType==='PERCENTAGE' ? '%' : 'Rs' %>
                                        <% if (offer.discountType==='PERCENTAGE' && offer.maxDiscountAmount) { %>
                                            (Max: Rs <%= offer.maxDiscountAmount %>)
                                        <% } %>
                                    </td>
                                    <td><%= new Date(offer.endDate).toLocaleDateString() %></td>
                                    <td>
                                        <span class="badge badge-<%= offer.isActive ? 'success' : 'danger' %>">
                                            <%= offer.isActive ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td><%= offer.usageCount %>/<%= offer.usageLimit || 'Infinity' %></td>
                                    <td>
                                        <div class="admin-actions">
                                            <a href="/admin/offers/edit/<%= offer._id %>" class="btn btn-sm btn-primary">Edit</a>
                                            <form action="/admin/offers/toggle/<%= offer._id %>" method="POST" class="d-inline m-0">
                                                <button type="submit" class="btn btn-sm btn-warning">
                                                    <%= offer.isActive ? 'Deactivate' : 'Activate' %>
                                                </button>
                                            </form>
                                            <form action="/admin/offers/delete/<%= offer._id %>" method="POST" class="d-inline m-0"
                                                onsubmit="return confirm('Are you sure you want to delete this offer?');">
                                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function showOfferForm() {
        const offerType = document.getElementById('offerTypeSelect').value;
        document.getElementById('offerType').value = offerType;

        document.querySelectorAll('.offer-form').forEach(form => {
            form.classList.remove('active-form');
        });

        if (offerType) {
            document.getElementById(offerType.toLowerCase() + 'Form').classList.add('active-form');
        }

        setRequiredFields(offerType);
    }

    function setRequiredFields(offerType) {
        document.querySelector('[name="categoryId"]')?.removeAttribute('required');
        document.querySelector('[name="productId"]')?.removeAttribute('required');
        document.querySelectorAll('[name^="referralDetails"]').forEach(el => el.removeAttribute('required'));

        switch (offerType) {
            case 'CATEGORY':
                document.querySelector('[name="categoryId"]').setAttribute('required', '');
                break;
            case 'PRODUCT':
                document.querySelector('[name="productId"]').setAttribute('required', '');
                break;
            case 'REFERRAL':
                document.querySelectorAll('[name^="referralDetails"]').forEach(el => el.setAttribute('required', ''));
                break;
        }
    }

    function toggleMaxDiscount() {
        const discountType = document.querySelector('[name="discountType"]').value;
        const maxDiscountDiv = document.getElementById('maxDiscountDiv');
        const maxDiscountInput = document.querySelector('[name="maxDiscountAmount"]');

        if (discountType === 'PERCENTAGE') {
            maxDiscountDiv.style.display = 'block';
            maxDiscountInput.setAttribute('required', '');
        } else {
            maxDiscountDiv.style.display = 'none';
            maxDiscountInput.removeAttribute('required');
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        toggleMaxDiscount();
    });
</script>
