<link rel="stylesheet" href="/stylesheets/salesReport.css">

<div class="main-content sales-report-page">
    <div class="admin-page admin-page--compact">
        <div class="admin-form-card mb-4">
            <form method="GET" action="/admin/sales-report" class="admin-form-grid admin-filter">
                <div class="form-group">
                    <label for="startDate">Start Date</label>
                    <input type="date" id="startDate" name="startDate" value="<%= startDate %>" class="form-control">
                </div>

                <div class="form-group">
                    <label for="endDate">End Date</label>
                    <input type="date" id="endDate" name="endDate" value="<%= endDate %>" class="form-control">
                </div>

                <div class="form-group">
                    <label for="reportType">Report Type</label>
                    <select id="reportType" name="reportType" class="form-control">
                        <option value="daily" <%=reportType==='daily' ? 'selected' : '' %>>Daily</option>
                        <option value="weekly" <%=reportType==='weekly' ? 'selected' : '' %>>Weekly</option>
                        <option value="monthly" <%=reportType==='monthly' ? 'selected' : '' %>>Monthly</option>
                    </select>
                </div>

                <div class="form-group d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Generate Report</button>
                </div>
            </form>
        </div>

        <div class="summary-grid">
            <div class="admin-card summary-card">
                <div class="label">Total Sales Count</div>
                <p><%= report.totalSalesCount %></p>
            </div>
            <div class="admin-card summary-card">
                <div class="label">Total Order Amount</div>
                <p>Rs <%= report.totalOrderAmount.toFixed(2) %></p>
            </div>
            <div class="admin-card summary-card">
                <div class="label">Total Discount</div>
                <p>Rs <%= report.totalDiscount.toFixed(2) %></p>
            </div>
            <div class="admin-card summary-card">
                <div class="label">Net Sales</div>
                <p>Rs <%= report.netSales.toFixed(2) %></p>
            </div>
        </div>

        <div class="actions">
            <a href="/admin/sales-report/pdf?startDate=<%= startDate %>&endDate=<%= endDate %>&reportType=<%= reportType %>" class="download-link">
                Download PDF
            </a>
            <a href="/admin/sales-report/excel?startDate=<%= startDate %>&endDate=<%= endDate %>&reportType=<%= reportType %>" class="download-link">
                Download Excel
            </a>
        </div>

        <div class="admin-table-card">
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th><%= reportType==='monthly' ? 'Month' : reportType==='weekly' ? 'Week' : 'Date' %></th>
                            <th>Subtotal</th>
                            <th>Discount</th>
                            <th>Final Amount</th>
                            <th>Order Count</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% orders.forEach(order=> { %>
                            <tr>
                                <td>
                                    <% if (reportType==='monthly' ) { %>
                                        <%= moment(order.createdAt).format('MMMM YYYY') %>
                                    <% } else if (reportType==='weekly' ) { %>
                                        <%= moment(order.createdAt).format('YYYY-[Week] WW') %>
                                    <% } else { %>
                                        <%= order.createdAt.toISOString().slice(0, 10) %>
                                    <% } %>
                                </td>
                                <td>Rs <%= order.subtotal.toFixed(2) %></td>
                                <td>Rs <%= order.discountAmount.toFixed(2) %></td>
                                <td>Rs <%= order.finalAmount.toFixed(2) %></td>
                                <td><%= order.orderCount || 1 %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <%- include('adminPagination', { pagination, basePath: '/admin/sales-report' }) %>
    </div>
</div>
