<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/stylesheets/layoutStyle.css">
    <link rel="stylesheet" href="/stylesheets/adminShell.css">
    <link rel="stylesheet" href="/stylesheets/editProducts.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</head>

<body class="admin-standalone">
    <div class="admin-form-page">
        <div class="admin-form-heading">
            <p class="admin-page-header__eyebrow">Inventory</p>
            <h1>Edit Product</h1>
            <p>Update product presentation details while keeping the current behavior intact.</p>
        </div>

        <% if (error_msg && error_msg.length) { %>
            <div class="alert alert-danger mb-4">
                <%= error_msg %>
            </div>
        <% } %>

        <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" class="admin-product-form admin-form-card">
            <div class="admin-form-grid">
                <div class="form-group">
                    <label for="productName">Product Name</label>
                    <input type="text" id="productName" name="productName" class="form-control"
                        value="<%= product.productName %>" required>
                </div>

                <div class="form-group">
                    <label for="variant">Variant</label>
                    <input type="text" id="variant" name="variant" class="form-control" value="<%= product.variant %>"
                        required>
                </div>

                <div class="form-group">
                    <label for="stock">Stock</label>
                    <input type="number" id="stock" name="stock" class="form-control" value="<%= product.stock %>"
                        required>
                </div>

                <div class="form-group">
                    <label for="price">Price</label>
                    <input type="number" id="price" name="price" class="form-control" value="<%= product.price %>"
                        required>
                </div>

                <div class="form-group">
                    <label for="category">Category</label>
                    <select id="category" name="category" class="form-control" required>
                        <option value="" disabled>Select a category</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" class="form-control"
                        required><%= product.description %></textarea>
                </div>
            </div>

            <div class="mt-4">
                <label class="d-block mb-3 font-weight-bold">Product Images</label>
                <div class="image-upload-container">
                    <% product.images.forEach((image, index)=> { %>
                        <div class="image-upload-slot">
                            <label>Image <%= index + 1 %></label>
                            <input type="file" class="form-control image-input" data-index="<%= index %>" accept="image/*">
                            <input type="hidden" name="croppedImage<%= index + 1 %>" id="croppedImage<%= index + 1 %>">
                            <div class="image-preview">
                                <img src="<%= image %>" alt="Existing image" class="img-fluid">
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="admin-actions mt-4">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="/admin/products" class="btn btn-outline-dark">Back to Products</a>
            </div>
        </form>
    </div>

    <div class="modal fade admin-modal" id="cropperModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Crop Image</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="img-container">
                        <img id="cropperImage" src="" alt="Image to crop" style="max-width: 100%;">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="cropButton">Crop</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let cropper;
            let currentImageIndex;
            const modal = document.getElementById('cropperModal');
            const cropperImage = document.getElementById('cropperImage');
            const cropButton = document.getElementById('cropButton');

            document.querySelectorAll('.image-input').forEach(input => {
                input.addEventListener('change', function (e) {
                    const file = e.target.files[0];
                    if (file) {
                        currentImageIndex = this.dataset.index;
                        const reader = new FileReader();
                        reader.onload = function (event) {
                            cropperImage.src = event.target.result;
                            $(modal).modal('show');

                            if (cropper) {
                                cropper.destroy();
                            }

                            cropper = new Cropper(cropperImage, {
                                aspectRatio: 1,
                                viewMode: 2
                            });
                        };
                        reader.readAsDataURL(file);
                    }
                });
            });

            cropButton.addEventListener('click', function () {
                const croppedCanvas = cropper.getCroppedCanvas();
                const croppedImage = croppedCanvas.toDataURL('image/jpeg');

                document.getElementById(`croppedImage${parseInt(currentImageIndex) + 1}`).value = croppedImage;

                const preview = document.querySelectorAll('.image-preview')[currentImageIndex];
                preview.innerHTML = `<img src="${croppedImage}" class="img-fluid">`;

                $(modal).modal('hide');
            });
        });

        document.addEventListener('DOMContentLoaded', function () {
            const categorySelect = document.getElementById('category');
            fetch('/admin/categories/json')
                .then(response => response.json())
                .then(categories => {
                    categories.forEach(category => {
                        const option = document.createElement('option');
                        option.value = category._id;
                        option.textContent = category.name;
                        if (String(category._id) === String('<%= product.category %>')) {
                            option.selected = true;
                        }
                        categorySelect.appendChild(option);
                    });
                })
                .catch(error => console.error('Error fetching categories:', error));
        });
    </script>
</body>

</html>
